# --- Database ---
# Free Postgres: https://neon.tech (or Supabase). Copy the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth ---
# Google Cloud Console > APIs & Services > Credentials > OAuth Client (Web)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="replace-me-access-secret"
JWT_REFRESH_SECRET="replace-me-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# --- AI ---
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"

# --- WhatsApp (Meta Cloud API) ---
# Leave blank to run in "sandbox" mode: outbound sends are logged + stored
# instead of actually calling Meta. Flip USE_REAL_WHATSAPP=true once you
# have real credentials — no code changes required.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="dev-verify-token"
WHATSAPP_APP_SECRET=""
USE_REAL_WHATSAPP="false"

# --- Email (Resend) ---
# Free tier: https://resend.com — get an API key, and for receiving
# inbound mail set up Resend's Inbound feature + a webhook pointed at
# /api/email/webhook, copy its signing secret below.
# Leave USE_REAL_EMAIL=false to run in sandbox mode (sends are logged,
# not delivered) — inbound webhook still works without a secret set
# (signature verification is skipped) for local testing via curl/Postman.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_WEBHOOK_SECRET=""
USE_REAL_EMAIL="false"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
